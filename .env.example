# PHNTM Asset Hub — env vars
# Copy to .env.local for dev. Set as Railway env vars for prod.

# Single-password auth gate. 24+ chars random.
HUB_PASSWORD=

# Cloudflare R2 (S3-compatible). Same bucket as content-engine.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=content-engine-asset-hub
R2_PUBLIC_BASE=https://pub-43a3cd33e89448d690e61af8d2e9a21e.r2.dev

# Companies (comma-separated slugs that the hub will surface in the picker)
COMPANIES=promptperfect,phntm-ai,smart-estates-law
